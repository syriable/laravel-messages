{
    "name": "syriable/laravel-messages",
    "description": "A backend-only one-to-one messaging system for Laravel: conversations, per-participant statuses, attachments, blocking, spam protection, reporting and search.",
    "keywords": [
        "syriable",
        "laravel",
        "laravel-messages",
        "messaging",
        "chat",
        "conversations"
    ],
    "homepage": "https://github.com/syriable/laravel-messages",
    "license": "MIT",
    "authors": [
        {
            "name": "Syriable",
            "email": "alkhatib.syr@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^12.0||^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^10.0.0||^11.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Syriable\\LaravelMessages\\": "src/",
            "Syriable\\LaravelMessages\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Syriable\\LaravelMessages\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Syriable\\LaravelMessages\\LaravelMessagesServiceProvider"
            ],
            "aliases": {
                "Messages": "Syriable\\LaravelMessages\\Facades\\Messages"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
